# Public Supabase project values from the Connect dialog
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only Supabase key. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Public canonical deployment URL, for example https://suryaindustries.example
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Token only, from Google Search Console's HTML tag verification method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_CONTACT_PHONE=+91 00000 00000
NEXT_PUBLIC_WHATSAPP_NUMBER=910000000000
NEXT_PUBLIC_CONTACT_EMAIL=quotes@your-verified-domain.example
NEXT_PUBLIC_FACTORY_ADDRESS=Peenya Industrial Area, Bengaluru, Karnataka
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/your-company
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/your-company

# Generate with: openssl rand -hex 32
LEAD_FINGERPRINT_SALT=your_random_64_character_hex_value

# Optional but recommended for immediate owner notifications
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Surya Industries <leads@your-verified-domain.example>
LEADS_TO_EMAIL=owner@example.com
